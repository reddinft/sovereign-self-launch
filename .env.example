# Public app URL used for Stripe redirects and metadata
NEXT_PUBLIC_BASE_URL=https://sovereign-self.preview.reddi.tech

# Turso (required for waitlist and early commitments)
TURSO_DATABASE_URL=libsql://...
TURSO_AUTH_TOKEN=...

# Stripe (optional until payments open; checkout returns 503 if placeholders remain)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_VARIANT_A_PRICE_ID=price_placeholder_a
STRIPE_VARIANT_B_PRICE_ID=price_placeholder_b
STRIPE_VARIANT_C_PRICE_ID=price_placeholder_c

# PostHog (optional; pricing falls back to founder variant if absent)
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Resend (optional; waitlist still succeeds if absent)
RESEND_API_KEY=

# Protect /api/cron/refunds when called by Coolify scheduled task or external cron
CRON_SECRET=change-me
