# Public app URL used for Stripe redirects and metadata
NEXT_PUBLIC_BASE_URL=https://sovereign-self.preview.reddi.tech

# Database
# Coolify preview uses persistent SQLite volume:
# TURSO_DATABASE_URL=file:/data/sovereign-self-launch.db
# Future Turso production can use libsql://... + TURSO_AUTH_TOKEN.
TURSO_DATABASE_URL=file:/data/sovereign-self-launch.db
TURSO_AUTH_TOKEN=local-preview

# Stripe (checkout returns 503 / pricing CTAs fall back to waitlist until these are real)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_VARIANT_A_PRICE_ID=price_placeholder_a
STRIPE_VARIANT_B_PRICE_ID=price_placeholder_b
STRIPE_VARIANT_C_PRICE_ID=price_placeholder_c
STRIPE_WEBHOOK_SECRET=whsec_...

# PostHog (optional; pricing analytics soft-degrade if absent)
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Resend (optional; waitlist still succeeds if absent)
RESEND_API_KEY=

# Cron + admin endpoints
CRON_SECRET=change-me
ADMIN_API_TOKEN=change-me
